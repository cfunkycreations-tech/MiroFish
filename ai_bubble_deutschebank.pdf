<input style="position:fixed;top:0px; left:-10000px "   id="dummyinput" ></input><h1 class="page-headline"  >“AI bubble” bubble bursts</h1><div  class="rfrwd-table rfrwd-table-ie_pdf  rwtab-init-hidden " id="rfrwd-table-1774444686603" ><article class="RWTAB17744446866030-row"   data-reweb-overlay="gal-overlay-dark"  data-reweb-log="{&quot;jquerySelector&quot;:null,&quot;domEvent&quot;:&quot;click&quot;,&quot;cpObjectType&quot;:&quot;P&quot;,&quot;cpObjectId&quot;:&quot;604456&quot;,&quot;cpObjectName&quot;:&quot;“AI bubble” bubble bursts&quot;,&quot;cpObjectAction&quot;:&quot;NA&quot;,&quot;cpObjectPath&quot;:&quot;P / 534787 / 604456&quot;,&quot;cpObjectWebPath&quot;:&quot;&quot;,&quot;cpObjectInfo1&quot;:&quot;&quot;,&quot;cpObjectInfo2&quot;:&quot;&quot;,&quot;cpObjectInfo3&quot;:&quot;REFIND&quot;,&quot;cpObjectLang&quot;:&quot;EN&quot;,&quot;cpWebstatGrp&quot;:&quot;WEBSTAT_RI&quot;} "  data-reweb-type="docu"  data-reweb-prodid="PROD0000000000604456"  id="RWTAB17744446866030-row-001"  data-reweb-linkcolor="gal-linkcolor-white"  data-reweb-padlock="false"  data-reweb-fontcolor="gal-fontcolor-white"  data-reweb="" ><div class="RWTAB17744446866030-showtopic2"   data-topic-values-0="STEFAN.ABRUDAN"  data-topic-values-1="ADRIAN.COX" ><div class="rfrwd-topic-label rfwd-topic-label-T2"  >Analysts</div><div class="rfrwd-topic-value rfwd-topic-value-T2"  ><span>Stefan Abrudan</span><span>Adrian Cox</span></div></div><div class="RWTAB17744446866030-showtopic1"   data-topic-values-0="RI_TEC" ><div class="rfrwd-topic-label rfwd-topic-label-T1"  >Topics</div><div class="rfrwd-topic-value rfwd-topic-value-T1"  ><a href="/PROD/IE-PROD/RI_TEC.alias"  title="All document tagged with &quot;Technology&quot;" >Technology</a></div></div><div class="RWTAB17744446866030-showtopic4"   data-topic-values-0="RI_FEA" ><div class="rfrwd-topic-label rfwd-topic-label-T4"  >Publication Type</div><div class="rfrwd-topic-value rfwd-topic-value-T4"  ><a href="/PROD/IE-PROD/RI_FEA.alias"  title="